# Copy to .env.local for development. NEVER commit real secrets.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser — keep secrets un-prefixed.

# Canonical site URL (used for metadata, sitemap, OG). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://christiancangelli.com

# --- Contact form (all optional until you wire email) ---
# Resend API key for delivering contact messages (server-only secret).
RESEND_API_KEY=
# Where contact messages are delivered.
CONTACT_TO_EMAIL=christiancangelli2007@gmail.com
# Verified "from" address on your email provider (transactional sender).
CONTACT_FROM_EMAIL=noreply@christiancangelli.com

# Cloudflare Turnstile (spam protection). Public key is safe to expose.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
